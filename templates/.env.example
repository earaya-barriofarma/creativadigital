# ─────────────────────────────────────────────────
# Creativa Digital — Environment Template
# ─────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit the actual .env file to version control.
#
# Usage:
#   cp .env.example .env
#   # then edit .env with your local values

# --- Bench / Frappe ---
# BENCH_PATH=benches/<client>-bench
# SITE_NAME=<client>.localhost

# --- Development ---
# FRAPPE_VERSION=v15.x.x
# PYTHON_VERSION=3.11

# --- Future: API keys, endpoints, etc. ---
# Add environment variables here as needed.
# Never commit real secrets to this repository.
